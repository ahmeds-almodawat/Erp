# Local Supabase default values after `supabase start`
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-local-or-remote-anon-key
VITE_BACKEND_MODE=local

# Set for Supabase pilot mode
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-public-anon-key
# VITE_BACKEND_MODE=supabase-pilot

# Edge Functions only; never expose this in frontend hosting
SUPABASE_SERVICE_ROLE_KEY=replace-only-in-edge-function-env
